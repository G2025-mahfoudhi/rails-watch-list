<%# <h1>Lists#show</h1>
<p>Find me in app/views/lists/show.html.erb</p> %>

<div class="hero" style="position: relative; background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('<%= @list.photo.attached? ? cl_image_path(@list.photo.key) : @list.image_url %>')">
  <div class="hero-content text-center text-white">
    <h1><%= @list.name %></h1>
  </div>
  <span class="badge" style="position: absolute; top: 20px; right: 20px; background-color: #f0a500; font-size: 1rem; padding: 8px 16px;">
    <%= @list.movies.count %> movies
  </span>
</div>



<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <%= link_to "← Back to lists", lists_path, class: "btn btn-outline-secondary" %>
    <div>
      <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-success" %>
      <%= link_to "Delete", list_path(@list), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, style: "color: red;" %>
    </div>
  </div>

  <div class="row">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>">
          <div class="card-body">
            <h5 class="card-title"><%= bookmark.movie.title %></h5>
            <p class="card-text text-muted"><%= bookmark.comment %></p>
            <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, style: "color: red;" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
