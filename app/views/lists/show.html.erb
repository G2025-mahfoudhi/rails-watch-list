<%# <h1>Lists#show</h1>
<p>Find me in app/views/lists/show.html.erb</p> %>

<div class="container mt-4">
  <h1><%= @list.name %></h1>

  <div class="row mt-4">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="<%= bookmark.movie.title %>">
          <div class="card-body">
            <h5 class="card-title"><%= bookmark.movie.title %></h5>
            <p class="card-text"><%= bookmark.comment %></p>
            <%= link_to "Remove", bookmark_path(bookmark), method: :delete, data: { turbo_method: :delete }, class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary mt-3" %>
</div>
